{
  "name": "offline-ai-coach-os",
  "private": true,
  "version": "1.0.0",
  "description": "Offline AI Personal Coach and Life Operating System (MERN)",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "server": "npm run dev --workspace server",
    "client": "npm run dev --workspace client",
    "start": "npm run dev --workspace client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --workspace client",
    "generate:foods": "node scripts/generateFoodDatabase.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.0"
  }
}
